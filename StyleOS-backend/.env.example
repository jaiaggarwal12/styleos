PORT=5000

# Oracle DB (your existing Oracle 21c installation)
DB_USER=system
DB_PASSWORD=change_this_to_your_real_db_password
DB_CONNECT=localhost:1521/XEPDB1

JWT_SECRET=change_this_to_a_long_random_string

# LLM — Ollama (free, local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Voice — Whisper (free, local)
# pip install openai-whisper
WHISPER_MODEL=medium

# Public URL for demo (ngrok free tier)
PUBLIC_URL=http://localhost:3000
CLIENT_URL=http://localhost:3000
